function [J, grad_J] = costFunctionAndGradient(u_vec, State_Initial, delta_in, Np, Nc, T, Yref, Q, R, S, X_obs, Y_obs, C_alpha_f, C_alpha_r, m, Iz, lf, lr)
    delta_seq = zeros(Np, 1);
    for i = 1:Np
        if i <= Nc
            delta_seq(i) = delta_in + u_vec(i);
        else
            delta_seq(i) = delta_in + u_vec(end);
        end
    end
    [vx_pred, vy_pred, psi_pred, Y_pred, X_pred] = predictTrajectory(delta_seq, State_Initial, Np, T, C_alpha_f, C_alpha_r, m, Iz, lf, lr);
    Y_error = Y_pred - Yref;
    if length(Y_error) < Np
        Y_error_padded = [Y_error; zeros(Np - length(Y_error), 1)];
    else
        Y_error_padded = Y_error(1:Np);
    end
    tracking_cost = Y_error_padded' * Q * Y_error_padded;
    control_cost  = u_vec(1:Nc)' * R * u_vec(1:Nc);
    J_obs_sum = 0;
    for k = 1:Np
        current_pos = [X_pred(k); Y_pred(k)];
        min_dist_sq = inf;
        for j = 1:length(X_obs)
            obs_center_x = X_obs(j);
            obs_center_y = Y_obs(j);
            dist_sq = (current_pos(1) - obs_center_x)^2 + (current_pos(2) - obs_center_y)^2;
            min_dist_sq = min(min_dist_sq, dist_sq);
        end
        safe_dist = 5.0; 
        sigma = 2.0; 
        if min_dist_sq < safe_dist^2
            penalty_factor = exp(-min_dist_sq / (sigma^2 + 1e-6)); 
            J_obs_sum = J_obs_sum + penalty_factor;
        end
    end
    obstacle_cost = S * J_obs_sum;
    J = tracking_cost + control_cost + obstacle_cost;
    n_u = length(u_vec);
    grad_J = zeros(n_u, 1);
    eps_grad = 1e-6; 
    for i = 1:n_u
        u_plus = u_vec; u_minus = u_vec;
        u_plus(i) = u_plus(i) + eps_grad;
        u_minus(i) = u_minus(i) - eps_grad;
        delta_seq_plus = zeros(Np, 1);
        for k = 1:Np
            if k <= Nc
                delta_seq_plus(k) = delta_in + u_plus(k);
            else
                delta_seq_plus(k) = delta_in + u_plus(end);
            end
        end
        [~, _, psi_plus, Y_plus, X_plus] = predictTrajectory(delta_seq_plus, State_Initial, Np, T, C_alpha_f, C_alpha_r, m, Iz, lf, lr);
        Y_error_plus = Y_plus - Yref;
        if length(Y_error_plus) < Np
            Y_error_padded_plus = [Y_error_plus; zeros(Np - length(Y_error_plus), 1)];
        else
            Y_error_padded_plus = Y_error_plus(1:Np);
        end
        J_plus = Y_error_padded_plus' * Q * Y_error_padded_plus + ...
                 u_plus(1:Nc)' * R * u_plus(1:Nc);
        J_obs_sum_plus = 0;
        for k = 1:Np
            current_pos_plus = [X_plus(k); Y_plus(k)];
            min_dist_sq_plus = inf;
            for j = 1:length(X_obs)
                obs_center_x = X_obs(j);
                obs_center_y = Y_obs(j);
                dist_sq_plus = (current_pos_plus(1) - obs_center_x)^2 + (current_pos_plus(2) - obs_center_y)^2;
                min_dist_sq_plus = min(min_dist_sq_plus, dist_sq_plus);
            end
            if min_dist_sq_plus < safe_dist^2
                penalty_factor_plus = exp(-min_dist_sq_plus / (sigma^2 + 1e-6)); 
                J_obs_sum_plus = J_obs_sum_plus + penalty_factor_plus;
            end
        end
        J_plus = J_plus + S * J_obs_sum_plus;
        delta_seq_minus = zeros(Np, 1);
        for k = 1:Np
            if k <= Nc
                delta_seq_minus(k) = delta_in + u_minus(k);
            else
                delta_seq_minus(k) = delta_in + u_minus(end);
            end
        end
        [~, _, psi_minus, Y_minus, X_minus] = predictTrajectory(delta_seq_minus, State_Initial, Np, T, C_alpha_f, C_alpha_r, m, Iz, lf, lr);
        Y_error_minus = Y_minus - Yref;
        if length(Y_error_minus) < Np
            Y_error_padded_minus = [Y_error_minus; zeros(Np - length(Y_error_minus), 1)];
        else
            Y_error_padded_minus = Y_error_minus(1:Np);
        end
        J_minus = Y_error_padded_minus' * Q * Y_error_padded_minus + ...
                  u_minus(1:Nc)' * R * u_minus(1:Nc);
        J_obs_sum_minus = 0;
        for k = 1:Np
            current_pos_minus = [X_minus(k); Y_minus(k)];
            min_dist_sq_minus = inf;
            for j = 1:length(X_obs)
                obs_center_x = X_obs(j);
                obs_center_y = Y_obs(j);
                dist_sq_minus = (current_pos_minus(1) - obs_center_x)^2 + (current_pos_minus(2) - obs_center_y)^2;
                min_dist_sq_minus = min(min_dist_sq_minus, dist_sq_minus);
            end
            if min_dist_sq_minus < safe_dist^2
                penalty_factor_minus = exp(-min_dist_sq_minus / (sigma^2 + 1e-6)); 
                J_obs_sum_minus = J_obs_sum_minus + penalty_factor_minus;
            end
        end
        J_minus = J_minus + S * J_obs_sum_minus;
        grad_J(i) = (J_plus - J_minus) / (2 * eps_grad);
    end
end
