function Mz = smc_controller(x, VehiclePara)
====================== 1. 参数提取 ==========================
lf = single(VehiclePara.lf);
lr = single(VehiclePara.lr);
Iz = single(VehiclePara.Iz);
beta      = single(x(1));
omega     = single(x(2));
delta     = single(x(3));
vx_raw    = single(x(4));
beta_ref  = single(x(5));
omega_ref = single(x(6));
Cf = single(x(7));
Cr = single(x(8));
if vx_raw < single(0.5)
    vx = single(0.5); 
else
    vx = vx_raw;
end
====================== 2. 状态误差计算 ======================
e_omega = omega - omega_ref;
====================== 3. 滑模面设计 ========================
lambda = single(2.0); 
alpha_f = delta - (beta + lf * omega / vx);
alpha_r = -(beta - lr * omega / vx);

Fyf = Cf * alpha_f;
Fyr = Cr * alpha_r;
omega_dot_nominal = (lf * Fyf - lr * Fyr) / Iz;
omega_ref_dot = single(x(9));
s = (omega_dot_nominal - omega_ref_dot) + lambda * e_omega;
===================== 4. 控制律设计=========================
k_gain = single(3000.0); 
boundary = single(0.05);  
Mz_eq = -Iz * (omega_dot_nominal - omega_ref_dot + lambda * e_omega);
s_sat = sat(s, boundary); 
Mz_sw = -k_gain * s_sat;
Mz = Mz_eq + Mz_sw;
===================== 5. 输出限幅与保护 ====================
Mz_max = single(5000.0); 
Mz_min = single(-5000.0);
if Mz > Mz_max
    Mz = Mz_max;
elseif Mz < Mz_min
    Mz = Mz_min;
end
end
