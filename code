function [region, dyc_gain, afs_gain] = fcn( beta_max, r_max, beta, r, ay, v_x, mu,C_n)
g = 9.81; 
region = 3;dyc_gain = 1.0;afs_gain = 0.0;
upper_bound = 0.67 * g * mu;
correction = 1 / (1 + 0.0025 * (v_x - 100)^2); 
if C_n > 0.8
	region = 3; dyc_gain = 1.0; afs_gain = 0.0;
else
if abs(beta) <= beta_max && abs(r) <= r_max
    lower_bound = (0.22 - 0.002 * v_x) * g;
    if ay < lower_bound
        region = 1;
        dyc_gain = 0.0;
        afs_gain = 1.0;      
    elseif ay >= lower_bound && ay <= upper_bound
        region = 2;        
        x = 20 * (ay - upper_bound + correction);
        dyc_gain = atan(x) / pi + max(0.625*abs(C_n),0.32);
        dyc_gain = max(0.0, min(1.0, dyc_gain)); 
        afs_gain = 1.0 - dyc_gain;
     else
        region = 3;
        dyc_gain = 1.0;
        afs_gain = 0.0;
    end
else
    region = 3;
    dyc_gain = 1.0;
    afs_gain = 0.0;
end
end
end
