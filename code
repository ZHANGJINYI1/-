function [Ctrl_SteerSW, t_Elapsed, DebugInfo] = mpc_variable_step_controller(u, VehiclePara, MPCParameters, Constraints, X_ref_input)
    t_Start = single(0);
    Calpha_f = single(u(35));
    Calpha_r = single(u(36));
    Vel_raw  = single(u(4)) / single(3.6); 
    if Vel_raw < single(1.0)
        Vel = single(1.0);
    else
        Vel = Vel_raw;
    end
    Vy       = single(u(5)) / single(3.6);
    yawrate  = single(u(6)) * single(pi/180);
    Rollrate = single(u(32)) * single(pi/180);
    Roll     = single(u(31)) * single(pi/180);
    fwa      = single(u(8)) * single(pi/180); 
    e_y      = single(u(40));
    e_psi    = single(u(41));
    Xm = [Vy; yawrate; Rollrate; Roll; e_y; e_psi];
    Nx = length(Xm); 
    ============== 1. 构建变步长离散模型 =======================
    Model = func_RigidbodyModel_FOH_Matrix_ROLL(VehiclePara, MPCParameters, Vel, Calpha_f, Calpha_r);
    As = Model.As;     
    Bs = Model.Bs_tot;  
    Al = Model.Al;    
    Bl = Model.Bl_tot;
    Nu = size(Bs, 2); 
    Np = MPCParameters.Np;
    Ns = MPCParameters.Ns;     
    ============= 2. 构建变步长预测矩阵 =======================
    Sc = zeros(Np*Nx, Nx, 'like', Xm);
    Su = zeros(Np*Nx, Np*Nu, 'like', Xm);
    A_curr = eye(Nx, 'like', Xm);
    for i = 1:Np
        if i <= Ns
            A_step = As;
        else
            A_step = Al;
        end
        A_curr = A_step * A_curr;
        Sc((i-1)*Nx+1:i*Nx, :) = A_curr;
        for j = 1:i
            if j <= Ns
                B_step_src = Bs;
            else
                B_step_src = Bl;
            end     
            if i == j
                B_col = B_step_src;
            else
                B_col = A_step * B_col;
            end
            col_start = (j-1)*Nu + 1;
            col_end = j*Nu;
            Su((i-1)*Nx+1:i*Nx, col_start:col_end) = B_col;
        end
    end
    ====================== 3. 构建 (H, G) ======================
    Wey     = single(MPCParameters.Wey);
    Wephi   = single(MPCParameters.Wephi);
    R_weight = single(MPCParameters.R_weight);
    sqrt_Q = zeros(Np*Nx, 1, 'like', Xm);
    for k = 0:Np-1
        idx_base = k*Nx;
        sqrt_Q(idx_base+5) = sqrt(Wey);
        sqrt_Q(idx_base+6) = sqrt(Wephi);
    end
    X_ref = single(X_ref_input);
    Su_w = zeros(size(Su), 'like', Xm);
    Err_free = Sc * Xm - X_ref;
    Err_w = zeros(size(Err_free), 'like', Xm);
    for row = 1:(Np*Nx)
        w = sqrt_Q(row);
        if w > single(0)
            for col = 1:(Np*Nu)
                Su_w(row, col) = Su(row, col) * w;
            end
            Err_w(row) = Err_free(row) * w;
        end
    end
    H_mat = single(2.0) * (Su_w' * Su_w) + single(2.0) * R_weight * eye(Np*Nu, 'like', Xm);
    G_vec = single(2.0) * (Su_w' * Err_w);
    ====================== 4. QP 求解  =======================
    delta_u_seq = zeros(Np*Nu, 1, 'like', Xm);
    alpha = single(MPCParameters.SolverAlpha);
    max_iter = MPCParameters.MaxIter;
    umax = single(Constraints.umax);
    dumax_rate = single(Constraints.dumax_rate);
    dumax = dumax_rate * MPCParameters.Ts;
    u_min = -umax; u_max = umax;
    du_min = -dumax; du_max = dumax;
    prev_u_base = fwa; 
    
    for iter = 1:max_iter
        grad = H_mat * delta_u_seq + G_vec;
        delta_u_candidate = delta_u_seq - alpha * grad;
        current_u = prev_u_base;
        for j = 1:(Np*Nu)
            du = delta_u_candidate(j);
            if du < du_min, du = du_min; end
            if du > du_max, du = du_max; end
            next_u = current_u + du;
            if next_u < u_min
                du = u_min - current_u;
            elseif next_u > u_max
                du = u_max - current_u;
            end
            if du < du_min, du = du_min; end
            if du > du_max, du = du_max; end       
            delta_u_candidate(j) = du;
            current_u = current_u + du;
        end
        delta_u_seq = delta_u_candidate;
    end
    fwa_opt = fwa + delta_u_seq(1);
    ==================== 5. 输出处理 =========================
    if fwa_opt > u_max, fwa_opt = u_max; end
    if fwa_opt < u_min, fwa_opt = u_min; end
    Ctrl_SteerSW = single(25) * fwa_opt * single(180/pi);
    t_Elapsed = single(0); 
    DebugInfo.Vel = Vel;
    DebugInfo.Iterations = max_iter;
    DebugInfo.ModelType = 'VariableStep_PadeAugmented_v2_Corrected_IndependentXref';
end
