function y = sat(s, boundary)
    s_single = s;
    boundary_single = boundary;
    if boundary_single <= single(0)
        y = sign(s_single);
        return;
    end
    abs_s = abs(s_single);
    if abs_s <= boundary_single
        y = s_single / boundary_single;
    else
        y = sign(s_single);
    end
end
