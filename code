function [StateSpaceModel] = func_RigidbodyModel_FOH_Matrix_ROLL(VehiclePara, MPCParameters, Vel, Calpha_f, Calpha_r)
    M       = single(VehiclePara.M);
    Iz      = single(VehiclePara.Iz);
    Ix      = single(VehiclePara.Ix);
    hCG     = single(VehiclePara.hCG);
    lf      = single(VehiclePara.lf);
    lr      = single(VehiclePara.lr);
    g       = single(9.81);
    K_phi   = single(VehiclePara.K_phi); 
    D_phi   = single(VehiclePara.D_phi); 
    Theta_1 = Calpha_f + Calpha_r;
    Theta_2 = Calpha_f * lf - Calpha_r * lr;
    Theta_3 = Calpha_f * lf^2 + Calpha_r * lr^2;
    Vel_safe = max(Vel, single(1.0));
    Mint = [ M,       0,       -M*hCG,        0;
           0,        Iz,       0,             0;
           -M*hCG,  0,       Ix+M*hCG^2,   0;
           0,        0,       0,             1 ];
    Nint = [ -Theta_1/Vel_safe,    M*Vel_safe - Theta_2/Vel_safe,   0,           single(0); 
             -Theta_2/Vel_safe,    -Theta_3/Vel_safe,            0,           single(0);
             0,                    -M*hCG*Vel_safe,                 D_phi,       K_phi - M*g*hCG;
             0,                    0,                       -1,          single(0) ];
    F1int = [-Calpha_f; -lf*Calpha_f; 0; 0]; 
    Ac_11 = -inv(Mint) * Nint; 
    B1cn_11 = inv(Mint) * F1int; 
    Nx_total = 6;
    Ac_12 = zeros(4, 2);
    Ac_21 = [1, 0, 0, 0; 0, 1, 0, 0]; 
    Ac_22 = [0, Vel_safe; 0, 0];
    B1cn_12 = [0; 0];
    Acn = [Ac_11, Ac_12; Ac_21, Ac_22];
    B1cn = [B1cn_11; B1cn_12];
    Ts  = single(MPCParameters.Ts);
    Tsl = single(MPCParameters.Tsl);
    Nx  = size(Acn, 1); 
    Nu  = size(B1cn, 2); 
    As = eye(Nx) + Ts * Acn;
    Bs_tot = Ts * B1cn; 
    M_aug = [Acn * Tsl, B1cn * Tsl; 
             zeros(Nu, Nx + Nu)]; 
    M_exp = func_matrix_exponential_pade(M_aug, 2);
    Al = M_exp(1:Nx, 1:Nx);
    Bl_tot = M_exp(1:Nx, Nx+1:Nx+Nu); 
    StateSpaceModel.Acn     = Acn;
    StateSpaceModel.B1cn    = B1cn;
    StateSpaceModel.As      = As;
    StateSpaceModel.Bs_tot  = Bs_tot;
    StateSpaceModel.Al      = Al;
    StateSpaceModel.Bl_tot  = Bl_tot;
end
