function Y = func_matrix_exponential_pade(A, order)
    %#codegen
    [n, ~] = size(A);
    I_n = eye(n, 'like', A);
    
    if order == 2
        A2 = A * A;
        c2 = single(1.0/12.0);
        c1 = single(0.5);
        Num = I_n + A * c1 + A2 * c2;
        Den = I_n - A * c1 + A2 * c2;
        Y = inv(Den) * Num; 
    else
        Y = I_n + A;
    end
end
