function [vx_pred, vy_pred, psi_pred, Y_pred, X_pred] = predictTrajectory(delta_seq, State_Initial, Np, T, C_alpha_f, C_alpha_r, m, Iz, lf, lr)
vy0 = State_Initial(1);
vx0 = State_Initial(2);
psi0 = State_Initial(3);
Y0 = State_Initial(4);
X0 = State_Initial(5);
if C_alpha_f <= 0 || C_alpha_r <= 0 || m <= 0 || Iz <= 0 || lf <= 0 || lr <= 0
    error('Parameters C_alpha_f, C_alpha_r, m, Iz, lf, lr must be positive values.');
end
vx_pred = zeros(Np, 1);
vy_pred = zeros(Np, 1);
psi_pred = zeros(Np, 1);
Y_pred = zeros(Np, 1);
X_pred = zeros(Np, 1);
vy_current = vy0;
psi_dot_current = 0; 
psi_current = psi0;
Y_current = Y0;
X_current = X0;
for k = 1:Np
    vx_pred(k) = vx0; 
    state_current = [vy_current; psi_dot_current];
    psi_current_state = psi_current;
    input_delta = delta_seq(k);
    d_state_k1 = dynamics(state_current, input_delta, vx0, C_alpha_f, C_alpha_r, m, Iz, lf, lr);
    d_psi_k1 = state_current(2); 
    d_Y_k1 = vx0 * sin(psi_current_state) + vy_current * cos(psi_current_state);
    d_X_k1 = vx0 * cos(psi_current_state) - vy_current * sin(psi_current_state);
    state_k2 = state_current + (T/2) * d_state_k1;
    psi_k2 = psi_current + (T/2) * d_psi_k1;
    Y_k2 = Y_current + (T/2) * d_Y_k1;
    X_k2 = X_current + (T/2) * d_X_k1;
    d_state_k2 = dynamics(state_k2, input_delta, vx0, C_alpha_f, C_alpha_r, m, Iz, lf, lr);
    d_psi_k2 = state_k2(2);
    d_Y_k2 = vx0 * sin(psi_k2) + state_k2(1) * cos(psi_k2);
    d_X_k2 = vx0 * cos(psi_k2) - state_k2(1) * sin(psi_k2);
    state_k3 = state_current + (T/2) * d_state_k2;
    psi_k3 = psi_current + (T/2) * d_psi_k2;
    Y_k3 = Y_current + (T/2) * d_Y_k2;
    X_k3 = X_current + (T/2) * d_X_k2;
    d_state_k3 = dynamics(state_k3, input_delta, vx0, C_alpha_f, C_alpha_r, m, Iz, lf, lr);
    d_psi_k3 = state_k3(2);
    d_Y_k3 = vx0 * sin(psi_k3) + state_k3(1) * cos(psi_k3);
    d_X_k3 = vx0 * cos(psi_k3) - state_k3(1) * sin(psi_k3);
    state_k4 = state_current + T * d_state_k3;
    psi_k4 = psi_current + T * d_psi_k3;
    Y_k4 = Y_current + T * d_Y_k3;
    X_k4 = X_current + T * d_X_k3;
    d_state_k4 = dynamics(state_k4, input_delta, vx0, C_alpha_f, C_alpha_r, m, Iz, lf, lr);
    d_psi_k4 = state_k4(2);
    d_Y_k4 = vx0 * sin(psi_k4) + state_k4(1) * cos(psi_k4);
    d_X_k4 = vx0 * cos(psi_k4) - state_k4(1) * sin(psi_k4);
    state_next = state_current + (T/6) * (d_state_k1 + 2*d_state_k2 + 2*d_state_k3 + d_state_k4);
    psi_next = psi_current + (T/6) * (d_psi_k1 + 2*d_psi_k2 + 2*d_psi_k3 + d_psi_k4);
    Y_next = Y_current + (T/6) * (d_Y_k1 + 2*d_Y_k2 + 2*d_Y_k3 + d_Y_k4);
    X_next = X_current + (T/6) * (d_X_k1 + 2*d_X_k2 + 2*d_X_k3 + d_X_k4);
    vy_current = state_next(1);
    psi_dot_current = state_next(2);
    psi_current = psi_next;
    Y_current = Y_next;
    X_current = X_next;
    vy_pred(k) = vy_current;
    psi_pred(k) = psi_current;
    Y_pred(k) = Y_current;
    X_pred(k) = X_current;
end
end
function d_state_dt = dynamics(state, input_delta, vx, C_alpha_f, C_alpha_r, m, Iz, lf, lr)
    vy = state(1);
    psi_dot = state(2);
    A11 = -(C_alpha_f + C_alpha_r) / (m * vx);
    A12 = (C_alpha_r * lr - C_alpha_f * lf) / (m * vx) - vx;
    A21 = (C_alpha_r * lr - C_alpha_f * lf) / (Iz * vx);
    A22 = -(C_alpha_r * lr^2 + C_alpha_f * lf^2) / (Iz * vx);
    B11 = C_alpha_f / m;
    B21 = C_alpha_f * lf / Iz;
    A = [A11, A12; A21, A22];
    B = [B11; B21];
    d_state_dt = A * state + B * input_delta;
end
